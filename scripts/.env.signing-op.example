# op reference config for bootstrap-signing-op.sh.
# Copy to scripts/.env.signing-op (gitignored) and point it at YOUR 1Password entry.
# These are NOT secrets — just the vault/item/field NAMES op reads the secrets from.

# 1Password vault + item holding the App Store Connect credentials.
export OP_VAULT='MyVault'
export OP_ITEM='AppStoreConnect'

# Field labels within that item. Defaults shown; override only if yours differ.
export OP_KEY_ID_FIELD='key_id'
export OP_ISSUER_ID_FIELD='issuer_id'
export OP_TEAM_ID_FIELD='team_id'
export OP_AUTH_KEY_B64_FIELD='auth_key_b64'   # base64 of the ASC .p8 API key

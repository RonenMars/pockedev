# App Store Connect API credentials for scripts/ship-ios.sh.
# Copy to .env.signing (gitignored) and fill in. Create the API key at:
#   https://appstoreconnect.apple.com/access/integrations/api  (Team Keys, role: App Manager)
#
#   source .env.signing && ./scripts/ship-ios.sh

export ASC_KEY_ID=XXXXXXXXXX                    # 10-char Key ID from the API keys page
export ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # Issuer ID (top of the same page)
export ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"  # the downloaded .p8
export ASC_TEAM_ID=GUW6BN8X57                    # Apple Developer Team ID
